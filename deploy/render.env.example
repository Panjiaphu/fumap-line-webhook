SECRET_KEY=__SET_IN_RENDER_SECRET__
DEBUG=false
ALLOWED_HOSTS=your-render-domain.onrender.com
CSRF_TRUSTED_ORIGINS=https://your-render-domain.onrender.com
DATABASE_URL=postgresql://__USER__:__PASSWORD__@__HOST__:5432/__DB_NAME__
APP_BASE_URL=https://your-render-domain.onrender.com
DEFAULT_LANGUAGE=vi
SECONDARY_LANGUAGE=zh-Hant
TIME_ZONE=Asia/Taipei
RATE_PROVIDER_MODE=live_with_manual_fallback
MANUAL_RATE_ENABLED=false
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=__SET_IN_RENDER_SECRET__
EMAIL_PORT=587
EMAIL_HOST_USER=__SET_IN_RENDER_SECRET__
EMAIL_HOST_PASSWORD=__SET_IN_RENDER_SECRET__
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=__SET_IN_RENDER_SECRET__

